  "rules": [
    "historical tabs are not discarded because Disponible desde did not exist yet",
    "missing Disponible desde never invents an eligibility date",
    "open/current periods require availability evidence for publishing available visits",
    "all operational and submission evidence columns remain fail-closed",
    "tab name is authoritative country evidence only for declared tab_scoped_compact headers",
    "missing ID CINEMA in a declared compact tab never invents a cinema identifier; hrRowId/sourceTab/sourceRow remain the identity evidence",
    "duplicate Fecha submitido columns coalesce only when one is populated or all populated values are equal"
  ],
  "prohibitions": [
    "first_partial_match_wins",
    "silent_column_fallback",
    "month_specific_column_map",
    "use_control_label_instead_of_explicit_evidence",
    "accept_ambiguous_header",
    "infer_historical_available_from_missing_column",
    "silent compact-header acceptance outside declared headerVariants",
    "coalesce conflicting duplicate evidence"
  ],
  "safeState": {
    "sourceSafe": true,
    "containsDataRows": false,
    "containsPii": false,
    "writes": false,
    "deploy": false,
