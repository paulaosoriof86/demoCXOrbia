    "certificationsMustNotBeInferred": true,
    "paidMustNotBeInferred": true,
    "shopperGapMustRemainInReview": true,
    "noNameMatching": true,
    "noAutomaticMerge": true
  },
  "decisions": {
    "aligned": "PASS_CANONICAL_MATERIALIZATION_SOURCE_ALIGNMENT_R16C",
    "overlayMissing": "HOLD_CANONICAL_MATERIALIZATION_PLAN_NEEDS_R14C_OVERLAY_R16C",
    "unsafe": "HARD_STOP_CANONICAL_MATERIALIZATION_SOURCE_ALIGNMENT_R16C"
  },
  "safeState": {
    "providerCalls": false,
    "writes": false,
    "deletes": false,
    "imports": false,
    "deploy": false,
    "production": false,
    "paymentsExecuted": false,
    "piiIncluded": false
  }
}
