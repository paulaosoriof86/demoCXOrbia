{
  "schemaVersion": "1.0.0",
  "contractId": "phase-a-canonical-materialization-source-alignment-r16c-v1",
  "purpose": "Verify that a canonical materialization plan distinguishes HR-derived settlement controls from R14C financial rows and does not infer certification or payment state.",
  "inputs": {
    "materializationPlan": ".tmp/r16c-materialization-plan/firestore-materialization-plan.json",
    "financialReconciliation": "backend/config/phase-a-financial-live-hr-reconciliation-r14c.source-safe.json",
    "shopperGap": "backend/config/phase-a-shopper-source-snapshot-gap-review-r11d.source-safe.json",
    "certificationProjection": "backend/config/phase-a-liquidation-certification-projection-summary.source-safe.json"
  },
  "scope": {
    "tenantId": "tya",
    "projectId": "cinepolis"
  },
  "required": {
    "hrVisits": 616,
    "liveShoppers": 210,
    "historicalShopperReferences": 213,
    "financialRows": 247,
    "financialExactLinks": 196,
    "financialReviewRows": 51,
    "financialReviewQueue": 92,
    "certificationCandidateShoppers": 213,
    "certificationSourceRecords": 0
  },
  "rules": {
    "visitDerivedLiquidationsAreControlRecords": true,
    "financialRowsMustOverlayByStableVisitId": true,
