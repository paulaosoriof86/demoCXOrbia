{
  "contractId": "phase-a-runtime-dev-switch-plan-v1",
  "tenantId": "tya",
  "projectId": "cinepolis",
  "mode": "runtime_switch_plan_only_no_execution",
  "createdAt": "2026-07-09",
  "purpose": "Definir el plan separado para un futuro runtime DEV switch Phase A, sin ejecutarlo y sin mezclarlo con la solicitud GO.",
  "separationPrinciples": {
