{
  "contractId": "phase-a-admin-actions-audit-contract-v1",
  "tenantId": "tya",
  "projectId": "cinepolis",
  "mode": "source_safe_contract_only_no_writes",
  "createdAt": "2026-07-09",
  "purpose": "Definir acciones administrativas auditables para Phase A sin activar writes reales, imports, runtime, HR writes ni pagos reales.",
  "principles": {
    "adminOperableFromPlatform": true,
    "writesAllowedNow": false,
    "previewOnlyUntilGate": true,
    "auditRequiredForEveryAction": true,
    "reasonRequiredForRiskActions": true,
    "noHardDelete": true,
    "logicalAnnulmentOnly": true,
    "tenantProjectScoped": true,
    "multiProjectSafe": true,
    "humanReviewForConflicts": true,
    "noVisualDeduplication": true,
    "noRuntimeSwitchWithoutPaulaGo": true
  },
  "auditEventRequiredFields": [
    "auditId",
    "tenantId",
    "projectId",
    "actorUid",
    "actorRole",
    "action",
    "entityType",
    "entityId",
    "beforeState",
    "afterState",
    "reasonCode",
    "source",
    "sourceRef",
    "idempotencyKey",
    "correlationId",
    "createdAt",
    "gateStatus"
  ],
  "auditEventOptionalSafeFields": [
    "visitId",
    "hrRowId",
    "shopperId",
    "assignmentSource",
    "assignmentSyncStatus",
    "lastSyncedAt",
    "projectRole",
    "reviewQueueId",
    "notesSafe",
    "metadataSafe"
  ],
  "forbiddenAuditFields": [
    "rawDpi",
    "dpi",
    "rawBankAccount",
    "bankAccount",
    "rawPhone",
    "phone",
    "rawEmail",
    "email",
    "rawShopperName",
    "serviceAccountJson",
    "makeWebhookUrl",
    "geminiApiKey",
    "paymentProviderToken",
    "rawEvidence",
    "base64Evidence"
  ],
  "actions": [
    {
      "action": "approve_application",
      "entityType": "application",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["application_pending", "available"],
      "toState": "assigned_from_platform_pending_hr_sync",
      "sideEffectsPreview": ["remove_from_available_preview", "queue_hr_sync_preview", "notify_preview_only"],
      "hardStops": ["missingShopperId", "duplicateAssignmentWithoutConflict", "visitAlreadyAssigned", "runtimeWriteEnabled"]
    },
    {
      "action": "reject_application",
      "entityType": "application",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "shopperId"],
      "fromStates": ["application_pending"],
      "toState": "application_rejected",
      "sideEffectsPreview": ["keep_traceability", "do_not_hard_delete_application"],
      "hardStops": ["hardDeleteAttempt", "missingReason"]
    },
    {
      "action": "reflect_platform_assignment_to_hr",
      "entityType": "assignment_sync",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId", "assignmentSource", "assignmentSyncStatus"],
      "fromStates": ["assigned_from_platform_pending_hr_sync"],
      "toState": "assigned_synced",
      "sideEffectsPreview": ["make_sync_preview_only", "hr_write_blocked_until_gate"],
      "hardStops": ["hrWriteBeforeGate", "missingHrRowId", "assignmentSourceConflict"]
    },
    {
      "action": "reflect_hr_assignment_to_platform",
      "entityType": "assignment_sync",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId", "assignmentSource", "assignmentSyncStatus"],
      "fromStates": ["assigned_from_hr_pending_platform_sync", "available"],
      "toState": "assigned_synced",
      "sideEffectsPreview": ["remove_from_available_preview", "platform_write_blocked_until_gate"],
      "hardStops": ["firestoreWriteBeforeGate", "missingShopperId", "duplicateAssignmentWithoutConflict"]
    },
    {
      "action": "resolve_sync_conflict",
      "entityType": "sync_conflict",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId"],
      "fromStates": ["sync_conflict_review"],
      "toState": "assigned_synced_or_available_or_cancelled_after_review",
      "sideEffectsPreview": ["human_review_required", "no_silent_overwrite"],
      "hardStops": ["visualNameOnlyDeduplication", "missingReason", "silentOverwriteAttempt"]
    },
    {
      "action": "request_reschedule",
      "entityType": "visit",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["scheduled"],
      "toState": "reschedule_requested",
      "sideEffectsPreview": ["validate_timeband_quincena_preview", "notify_preview_only"],
      "hardStops": ["dateOutOfRange", "missingReason"]
    },
    {
      "action": "approve_reschedule",
      "entityType": "visit",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["reschedule_requested"],
      "toState": "scheduled",
      "sideEffectsPreview": ["validate_timeband_quincena_preview", "hr_platform_sync_preview_only"],
      "hardStops": ["dateOutOfRange", "hrWriteBeforeGate", "firestoreWriteBeforeGate"]
    },
    {
      "action": "mark_completed",
      "entityType": "visit",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["scheduled"],
      "toState": "completed",
      "sideEffectsPreview": ["questionnaire_pending_control", "no_future_date"],
      "hardStops": ["futureCompletionDate", "missingStableKey"]
    },
    {
      "action": "mark_questionnaire_completed",
      "entityType": "questionnaire_event",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["completed"],
      "toState": "questionnaire_completed",
      "sideEffectsPreview": ["route_by_project_or_visit", "submit_pending_control"],
      "hardStops": ["futureQuestionnaireDate", "missingQuestionnaireRoute"]
    },
    {
      "action": "mark_submitted_by_tya",
      "entityType": "submitted_event",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId"],
      "fromStates": ["questionnaire_completed"],
      "toState": "submitted_by_tya",
      "sideEffectsPreview": ["enable_liquidation_candidate_preview"],
      "hardStops": ["hrSourceMissing", "futureSubmittedDate"]
    },
    {
      "action": "preserve_certification",
      "entityType": "certification",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "shopperId"],
      "fromStates": ["review_required", "preserved_already_presented"],
      "toState": "preserved_already_presented",
      "sideEffectsPreview": ["do_not_request_again", "mark_evidence_source_safe"],
      "hardStops": ["rawEvidenceInRepo", "requestAgainWithoutReview", "missingShopperId"]
    },
    {
      "action": "mark_certification_review_required",
      "entityType": "certification",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "shopperId"],
      "fromStates": ["required_new_or_expired", "preserved_already_presented", "passed"],
      "toState": "review_required",
      "sideEffectsPreview": ["human_review_required", "do_not_block_automatically_if_preserved"],
      "hardStops": ["automaticDecertificationWithoutReview", "missingReason"]
    },
    {
      "action": "create_liquidation_candidate",
      "entityType": "liquidation",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": false,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["submitted_by_tya"],
      "toState": "liquidation_candidate",
      "sideEffectsPreview": ["finance_crosscheck_required", "no_real_payment"],
      "hardStops": ["paymentMarkedReal", "missingHrRowId", "missingSubmittedEvent"]
    },
    {
      "action": "mark_payment_review",
      "entityType": "payment_control",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["liquidation_candidate"],
      "toState": "payment_review",
      "sideEffectsPreview": ["admin_finance_control_only"],
      "hardStops": ["realPaymentAttempt", "missingReason"]
    },
    {
      "action": "schedule_payment_control",
      "entityType": "payment_control",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["payment_review"],
      "toState": "payment_scheduled",
      "sideEffectsPreview": ["admin_schedule_only", "no_provider_payment"],
      "hardStops": ["paymentProviderToken", "realPaymentAttempt"]
    },
    {
      "action": "confirm_external_payment",
      "entityType": "payment_control",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "visitId", "hrRowId", "shopperId"],
      "fromStates": ["payment_review", "payment_scheduled"],
      "toState": "payment_confirmed_external",
      "sideEffectsPreview": ["external_confirmation_reference_required", "cxorbia_does_not_execute_payment"],
      "hardStops": ["missingExternalConfirmation", "paymentProviderExecutionAttempt"]
    },
    {
      "action": "annul_or_correct_admin_state",
      "entityType": "admin_correction",
      "allowedInPhaseA": true,
      "writesAllowedNow": false,
      "requiresAudit": true,
      "requiresReason": true,
      "requiresStableKeys": ["tenantId", "projectId", "entityId"],
      "fromStates": ["any_non_final_control_state"],
      "toState": "logical_annulled_or_corrected_after_review",
      "sideEffectsPreview": ["logical_annulment_only", "no_hard_delete"],
      "hardStops": ["hardDeleteAttempt", "missingBeforeAfter", "missingReason"]
    }
  ],
  "safeStateExpected": {
    "runtimeConnected": false,
    "firestoreWrites": false,
    "hrWrites": false,
    "importsExecuted": false,
    "deploy": false,
    "production": false,
    "makeWebhookLive": false,
    "geminiLive": false,
    "paymentProviderLive": false,
    "rawSensitiveDataInRepo": false
  }
}
