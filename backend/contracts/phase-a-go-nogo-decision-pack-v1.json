        "raw_sensitive_data_commit"
      ]
    },
    "GO_WITH_WARNINGS": {
      "meaning": "Future human smoke found no hard blocker, but warnings remain and must be documented before the next controlled step.",
      "allows": [
        "document_warnings",
        "continue_only_non_destructive_preparation",
        "create_targeted_claude_or_backend_followup"
      ],
      "doesNotAllow": [
