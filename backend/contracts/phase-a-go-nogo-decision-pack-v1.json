        "runtime_switch",
        "real_integrations",
        "imports",
        "payments"
      ]
    },
    "NO_GO": {
      "meaning": "Future human smoke found at least one critical blocker. Do not advance RC. Fix only root cause and re-run the relevant gate/check.",
      "allows": [
        "root_cause_documentation",
        "minimal_targeted_fix_only_when_authorized",
        "repeat_relevant_gate_or_smoke_after_fix"
      ],
      "doesNotAllow": [
        "broad_refactor",
        "repeating_level_0_1_without_documented_cause",
        "merge",
        "deploy",
        "production",
        "runtime_switch",
        "imports",
        "writes",
        "payments"
      ]
    },
    "HOLD": {
      "meaning": "Decision cannot be made because required future evidence is missing, ambiguous or not source-safe.",
      "allows": [
        "request_only_the_missing_non_private_evidence_or_authorization",
        "continue_safe_documentation"
      ],
      "doesNotAllow": [
        "guessing_go",
        "claiming_validation_done",
        "merge",
        "deploy",
        "production",
        "runtime_switch"
      ]
    }
  },
